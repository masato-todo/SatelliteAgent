+
+        def score(date_items):
+            union = None
+            for it in date_items:
+                geom = shape(it.geometry)
+                union = geom if union is None else union.union(geom)
+            coverage = (union.intersection(target).area / target_area) if union is not None else 0.0
+            cloud_mean = sum(it.properties.get('eo:cloud_cover', 100) for it in date_items) / len(date_items)
+            return (coverage, -cloud_mean / 100.0)
+
+        # Highest bbox-coverage date wins (tie-break: lower mean cloud, latest date).
+        best_date = max(by_date.keys(), key=lambda d: (*score(by_date[d]), d))
